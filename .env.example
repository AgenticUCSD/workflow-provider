# workflow-provider environment (copy to .env; .env is gitignored). Every var here is
# read by the app at runtime — see utils/config.py + utils/memory_client.py.

# --- Core ---
# Required for the LLM agents + embeddings. The app still boots without it (serves
# /health) but LLM/embedding calls fail until it's set.
OPENAI_API_KEY=your_openai_api_key_here

# --- Tracing (Confident AI / DeepEval) — optional ---
CONFIDENT_API_KEY=your_confident_api_key_here
# Flush traces eagerly (dev). Set by deepeval.
CONFIDENT_TRACE_FLUSH=1
# Set to false/0/off to force tracing off (e.g. offline).
# CONFIDENT_TRACING=true

# --- Store backend (Phase 1 shared store) ---
# chroma (default, per-service) | pg (shared planner schema).
STORE_BACKEND=chroma
# Chroma persistence dir (default ./chroma_db; containers use /tmp).
CHROMA_PERSIST_DIR=./chroma_db
# Required only when STORE_BACKEND=pg (the planner_app connection).
# PLANNER_DATABASE_URL=postgresql://planner_app:...@host:5432/workflow_executor?sslmode=require

# --- memory-unit wiring (flag-gated; unset = no memory calls) ---
# Base URL of the memory-unit service. Unset -> resolve()/populate is a no-op.
# MEMORY_URL=https://memory-unit-...run.app
# Auto-fill missing task slots from memory-unit inside /identify_task. Default off;
# a no-op unless MEMORY_URL is also set. (The standalone /populate_task_context works
# regardless.) NOTE: when memory-unit runs MEMORY_VALIDATE_TOKEN=on, the caller's
# Authorization bearer is forwarded automatically to /resolve.
# MEMORY_AUTO_POPULATE=false

# --- Template store tuning ---
# Optional cosine-distance threshold for SEMANTIC near-dup template dedup on create.
# Unset (default) = exact content-hash dedup only. Set a small value (e.g. 0.02) to
# also collapse near-identical templates — calibrate before enabling.
# TEMPLATE_NEAR_DUP_DISTANCE=0.02
